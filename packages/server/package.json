{
  "name": "@bulkhead/server",
  "version": "0.1.0",
  "description": "Bulkhead guardrails HTTP REST and MCP server",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/floatingsidewal/bulkhead.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/floatingsidewal/bulkhead#readme",
  "bugs": "https://github.com/floatingsidewal/bulkhead/issues",
  "keywords": [
    "bulkhead",
    "guardrails",
    "mcp",
    "content-safety",
    "pii",
    "secrets"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "bin": {
    "bulkhead-server": "./dist/main.js",
    "bulkhead-mcp": "./dist/mcp/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "start": "node dist/main.js",
