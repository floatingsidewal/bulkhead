    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@bulkhead/core": "^0.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "tsx": "^4.7.0"
  }
}
